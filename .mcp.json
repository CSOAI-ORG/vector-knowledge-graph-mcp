{
  "name": "vector-knowledge-graph-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs MCP Server",
  "version": "1.0.0",
  "tools": [
    {
      "name": "add_node",
      "description": "Add a node to the knowledge graph with properties, embeddings, and metadata.",
      "parameters": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "properties": {
            "type": "object"
          },
          "node_id": {
            "type": "string"
          }
        },
        "required": [
          "label",
          "properties"
        ]
      }
    },
    {
      "name": "add_edge",
      "description": "Create a directed edge between two nodes with relationship type and weight.",
      "parameters": {
        "type": "object",
        "properties": {
          "from_id": {
            "type": "string"
          },
          "to_id": {
            "type": "string"
          },
          "relation": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        },
        "required": [
          "from_id",
          "to_id",
          "relation"
        ]
      }
    },
    {
      "name": "semantic_node_search",
      "description": "Search for nodes using semantic similarity matching against stored embeddings.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "top_k": {
            "type": "integer"
          }
        },
        "required": [
          "query"
        ]
      }
    },
    {
      "name": "trace_compliance_chain",
      "description": "Trace the compliance chain from a requirement through controls to evidence.",
      "parameters": {
        "type": "object",
        "properties": {
          "start_node_id": {
            "type": "string"
          },
          "max_depth": {
            "type": "integer"
          }
        },
        "required": [
          "start_node_id"
        ]
      }
    },
    {
      "name": "find_gaps",
      "description": "Find gaps in the knowledge graph where expected relationships or nodes are missing.",
      "parameters": {
        "type": "object",
        "properties": {
          "required_frameworks": {
            "type": "array"
          }
        },
        "required": [
          "required_frameworks"
        ]
      }
    }
  ]
}